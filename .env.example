# ==========================================
# VLM Game Agent 配置文件
# 复制为 .env 后修改，无需改动代码
# ==========================================

# ---------- VLM API ----------
VLM_BASE_URL=http://127.0.0.1:1234/v1
VLM_MODEL=qwen3.6-27b
VLM_API_KEY=sk-no-key-required
VLM_MAX_TOKENS=4096
VLM_TEMPERATURE=0.3

# ---------- 截图配置 ----------
CAPTURE_SCALE=1.0
CAPTURE_FORMAT=PNG
CAPTURE_FPS=1.0
CAPTURE_AREA=client

# ---------- 时停控制 ----------
# 策略: soft(esc键) / hard(挂起进程) / focus(失焦暂停)
PAUSE_STRATEGY=hard
PAUSE_HOTKEY=esc
RESUME_HOTKEY=esc

# ---------- Agent 行为 ----------
AGENT_MAX_HISTORY_TURNS=6
AGENT_PAUSE_BEFORE_THINK=true
AGENT_ACTION_DELAY=1.0
AGENT_STOP_HOTKEY=f12

# ---------- 记忆系统 ----------
MEMORY_DIR=./memories

# ---------- WebUI ----------
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

# ---------- 快捷启动（设置后跳过交互输入） ----------
# WINDOW_TITLE=Plants vs. Zombies
# TASK=通过第一关
