# ==========================================
# VLM Game Agent 配置文件
# 复制为 .env 后修改，无需改动代码
# ==========================================

# ---------- VLM API ----------
VLM_BASE_URL=http://127.0.0.1:1234/v1
VLM_MODEL=qwen3.6-27b
VLM_API_KEY=sk-no-key-required
VLM_CONTEXT_SIZE=32768  # 模型上下文窗口总大小（token）
VLM_MAX_OUTPUT_TOKENS=4096  # 模型单次回复的最大长度（token）
VLM_TEMPERATURE=0.3

# ---------- 截图配置 ----------
CAPTURE_SCALE=1.0
CAPTURE_FORMAT=PNG
CAPTURE_FPS=1.0
CAPTURE_AREA=client

# ---------- 时停控制 ----------
# 策略: soft(esc键) / hard(挂起进程) / focus(失焦暂停)
PAUSE_STRATEGY=hard
PAUSE_HOTKEY=esc
RESUME_HOTKEY=esc

# ---------- Agent 行为 ----------
AGENT_MAX_HISTORY_TURNS=6
AGENT_PAUSE_BEFORE_THINK=true
AGENT_ACTION_DELAY=1.0
AGENT_STOP_HOTKEY=f12

# 动作感知延迟：执行不同动作后的最低观察等待时间（秒）
# 实际等待 = max(ACTION_DELAY, 本轮动作最大延迟, 模型主动wait)
# 调大这些值让游戏有更多时间响应，调小则加快 Agent 节奏
AGENT_DELAY_CLICK=2.0
AGENT_DELAY_DRAG=2.5
AGENT_DELAY_KEY=1.5
AGENT_DELAY_TYPE=1.0
AGENT_DELAY_IDLE=3.0

# 上下文压缩：当上下文 token 数达到窗口大小的指定比例时自动压缩
# 不需要暂停游戏，压缩使用独立模型（默认复用主 VLM）
AGENT_CONTEXT_COMPRESS_THRESHOLD=0.7
# 压缩模型（留空则复用主 VLM，可指定更小的模型加速压缩）
VLM_COMPRESS_BASE_URL=
VLM_COMPRESS_MODEL=
VLM_COMPRESS_API_KEY=

# ---------- 记忆系统 ----------
MEMORY_DIR=./memories

# ---------- 操作日志 ----------
ACTION_LOG_ENABLED=true
ACTION_LOG_DIR=./action_logs

# ---------- WebUI ----------
WEBUI_ENABLED=true
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080

# ---------- 快捷启动（设置后跳过交互输入） ----------
# WINDOW_TITLE=Plants vs. Zombies
# TASK=通过第一关

# ---------- PvZ 内存读取 ----------
# 启用后从 PvZ 进程内存直接读取游戏状态（阳光/卡片/植物/僵尸等）
# 需要以管理员权限运行，且 PvZ 游戏必须已启动
# PVZ_MEMORY_ENABLED=true
